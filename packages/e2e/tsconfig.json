{
  "extends": "@extension/tsconfig/utils",
  "compilerOptions": {
    "module": "ESNext",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["tests", "config", "utils"]
}
